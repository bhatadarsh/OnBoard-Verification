# ============================================
# AI HirePro Enterprise — Environment Config
# ============================================
# Copy this file as .env and fill in your values
# cp .env.example .env

# --- LLM (Groq) ---
GROQ_API_KEY=your-groq-api-key
LLM_MODEL=llama-3.3-70b-versatile

# --- Vision / OCR ---
# Used by OnboardGuard document extraction
# VISION_MODEL is resolved in code (defaults to meta-llama/llama-4-scout-17b-16e-instruct)

# --- Embeddings ---
# Provider: 'huggingface' (local, free) or 'openai' (API, paid)
EMBEDDING_PROVIDER=huggingface
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768
HF_DEVICE=cpu

# --- PostgreSQL (optional) ---
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/data_extraction

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=data_extraction

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=document_embeddings

# --- Processing ---
MAX_WORKERS=4
LOG_LEVEL=INFO

# --- LangSmith (optional, for tracing) ---
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_PROJECT=your-project-name
