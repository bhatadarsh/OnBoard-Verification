# ============================================
# Data Extraction Pipeline — Environment Config
# ============================================
# Copy this file as .env and fill in your values
# cp .env.example .env

# --- LLM (Gemini) ---
GEMINI_API_KEY=your-api-key
GEMINI_MODEL=gemini-2.5-flash

# --- Embeddings ---
# Provider: 'huggingface' (local, free) or 'openai' (API, paid)
EMBEDDING_PROVIDER=huggingface
OPENAI_API_KEY=your_openai_api_key_here
EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DIMENSIONS=768
HF_DEVICE=cpu
# HF_TOKEN= (only needed for gated models like google/embeddinggemma-300m)
HF_TOKEN=

# --- PostgreSQL ---
POSTGRES_URI=postgresql://postgres:postgres@localhost:5432/data_extraction

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=data_extraction

# --- ChromaDB ---
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=document_embeddings

# --- Processing ---
MAX_WORKERS=4
LOG_LEVEL=INFO

# --- Input ---
# Default input path (can be overridden via CLI)
DEFAULT_INPUT_PATH=../sample docs
