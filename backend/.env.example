# App Configuration
PROJECT_NAME="Onboarding Validator"
API_V1_STR="/api/v1"
ENVIRONMENT="development" # development, staging, production

# Security
SECRET_KEY="replace_with_a_secure_random_string"
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALLOWED_ORIGINS=["http://localhost:5173"]

# Google SSO
GOOGLE_CLIENT_ID="mock_client_id_for_dev"
GOOGLE_CLIENT_SECRET="mock_client_secret_for_dev"

# Database (PostgreSQL)
POSTGRES_SERVER="localhost"
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="password"
POSTGRES_DB="onboarding_db"

# LLM Keys
OPENAI_API_KEY="sk-..." # GROQ_API_KEY
